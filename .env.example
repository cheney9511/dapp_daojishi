# WalletConnect 项目 ID（使用 WalletConnect 扫码连接时必填；仅用注入式钱包如 MetaMask 可不填）
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# 是否使用 BSC 测试网：不设或非 'false' 时为测试网，设为 'false' 时使用 BSC 主网
# VITE_USE_TESTNET=true

# Phase 1 自建模式：Remix 部署 CDT + GameCore 后填入
# VITE_TOKEN_ADDRESS=0x...
# VITE_PROTOCOL_ADDRESS=0x...
